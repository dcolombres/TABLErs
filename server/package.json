{
  "name": "tablers-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend for Tablers analytics dashboard",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm --watch src/index.ts",
    "build": "npm run clean && tsc",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "migrate:make": "node --loader ts-node/esm ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:make",
    "migrate:latest": "node --loader ts-node/esm ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "node --loader ts-node/esm ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:rollback"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "knex": "^3.2.6",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.3",
    "onchange": "^7.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
